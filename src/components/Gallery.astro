---
export interface Props {
  images?: { src: string; alt: string }[];
  interval?: number;
}

const base = import.meta.env.BASE_URL;
const defaultImages = [
  { src: base + '1.webp', alt: 'Panel principal del ERP' },
  { src: base + '2.webp', alt: 'Módulo de inventario' },
  { src: base + '3.webp', alt: 'Módulo de finanzas' },
];

const { images = defaultImages, interval = 5000 } = Astro.props;
---

<section id="galeria" class="py-20 scroll-mt-20 bg-brand-base">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-2">
      <span class="text-xs tracking-widest text-brand-accent font-semibold">GALERÍA</span>
    </div>

    <h2 class="text-3xl md:text-4xl font-bold mb-4">Velo con tus propios ojos.</h2>
    <p class="text-gray-400 mb-12 max-w-2xl">
      Capturas reales de cada módulo de GA ERP para que veas lo que te espera.
    </p>

    <div
      class="carousel-wrapper relative overflow-hidden rounded-2xl max-w-6xl mx-auto"
      data-interval={interval}
    >
      <!-- Left fade overlay -->
      <div
        class="absolute left-0 top-0 bottom-0 w-12 sm:w-20 md:w-40 z-10 pointer-events-none"
        style="background: linear-gradient(to right, #0a0a0a 0%, transparent 100%);"
      ></div>

      <!-- Right fade overlay -->
      <div
        class="absolute right-0 top-0 bottom-0 w-12 sm:w-20 md:w-40 z-10 pointer-events-none"
        style="background: linear-gradient(to left, #0a0a0a 0%, transparent 100%);"
      ></div>

      <!-- Prev button -->
      <button
        class="carousel-prev absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-brand-card/80 hover:bg-brand-card border border-brand-border flex items-center justify-center transition"
        aria-label="Imagen anterior"
      >
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Next button -->
      <button
        class="carousel-next absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-brand-card/80 hover:bg-brand-card border border-brand-border flex items-center justify-center transition"
        aria-label="Imagen siguiente"
      >
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Track container -->
      <div class="carousel-container relative">
        <div
          class="carousel-track flex transition-transform duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)]"
          style="transform: translateX(calc(var(--current, 0) * -100%));"
        >
          {images.map((img) => (
            <div class="carousel-slide min-w-full flex-shrink-0 relative aspect-video max-h-[50vh] sm:max-h-[70vh] md:max-h-[600px]">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover rounded-2xl"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <div
                class="hidden absolute inset-0 flex-col items-center justify-center bg-brand-card rounded-2xl"
                aria-hidden="true"
              >
                <svg class="w-10 h-10 text-brand-accent mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <span class="text-gray-400 text-sm text-center px-4">{img.alt}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Navigation dots -->
    <div class="flex justify-center gap-2 mt-6">
      {images.map((_, i) => (
        <button
          class="carousel-dot rounded-full transition-all duration-300"
          data-index={i}
          aria-label={`Ir a la imagen ${i + 1}`}
          style="background: #2d2d2d; width: 8px; height: 8px;"
        ></button>
      ))}
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var container = document.querySelector('#galeria .carousel-container');
  if (!container) return;
  var wrapper = container.closest('.carousel-wrapper');
  var track = container.querySelector('.carousel-track');
  var dots = document.querySelectorAll('#galeria .carousel-dot');
  var interval = parseInt(wrapper.getAttribute('data-interval')) || 5000;
  var current = 0;
  var total = dots.length;
  if (total === 0) return;
  var timer;

  function goTo(index) {
    current = ((index % total) + total) % total;
    track.style.setProperty('--current', String(current));
    for (var i = 0; i < dots.length; i++) {
      dots[i].style.background = i === current ? '#3b82f6' : '#2d2d2d';
      dots[i].style.width = i === current ? '24px' : '8px';
    }
  }

  function startTimer() {
    timer = window.setInterval(function () { goTo(current + 1); }, interval);
  }

  function stopTimer() {
    window.clearInterval(timer);
  }

  goTo(0);
  startTimer();

  wrapper.addEventListener('mouseenter', stopTimer);
  wrapper.addEventListener('mouseleave', startTimer);

  var prevBtn = document.querySelector('#galeria .carousel-prev');
  var nextBtn = document.querySelector('#galeria .carousel-next');

  if (prevBtn) {
    prevBtn.addEventListener('click', function () {
      goTo(current - 1);
      stopTimer();
      startTimer();
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      goTo(current + 1);
      stopTimer();
      startTimer();
    });
  }

  for (var j = 0; j < dots.length; j++) {
    dots[j].addEventListener('click', function () {
      goTo(parseInt(this.getAttribute('data-index')));
      stopTimer();
      startTimer();
    });
  }

  window.restartGalleryInterval = function () {
    stopTimer();
    startTimer();
  };
})();
</script>
