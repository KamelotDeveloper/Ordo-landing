---
---

<section class="hero-wrapper">
  <canvas id="particles-canvas"></canvas>
  <div class="glow-radial"></div>
  <div class="glow-bottom"></div>
  <div class="grid-overlay"></div>
  <div class="scan-line"></div>
  <div class="hero-bottom-fade"></div>

  <div class="hero-content">
    <div class="badge">
      <span class="badge-dot"></span>
      Versión 1.2.0
      <span class="badge-divider"></span>
      <svg class="microsoft-badge-icon" viewBox="0 0 21 21" width="14" height="14" fill="none">
        <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
        <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
        <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
        <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
      </svg>
      Certificado por Microsoft
    </div>
    <div class="hero-title-row">
      <h1 class="hero-title">
      El ERP que tu empresa<br>
      <span class="accent">realmente necesita.</span>
    </h1>
    </div>
    <p class="hero-subtitle">
      GA Software unifica finanzas, inventario, ventas y operaciones en una
      sola plataforma. Tomá decisiones con datos, no con suposiciones.
    </p>
    <div class="hero-buttons">
      <a href="#" class="btn-primary" target="_blank" rel="noopener noreferrer">DOWNLOAD</a>
      <a href="#modulos" class="btn-secondary">▶ Ver módulos</a>
    </div>
  </div>

  <div class="hero-logo-wrap">
    <img src={import.meta.env.BASE_URL + "/GA logo.png"} alt="GA Software" class="hero-logo" />
  </div>
</section>

<style>
  .hero-wrapper {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: #0a0a0a;
    overflow: hidden;
    display: flex;
    align-items: center;
    font-family: 'Inter', system-ui, sans-serif;
  }

  #particles-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .glow-radial {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 55%;
    height: 120%;
    background: radial-gradient(ellipse at center,
      rgba(59,130,246,0.18) 0%,
      rgba(59,130,246,0.06) 40%,
      transparent 70%);
    z-index: 1;
    pointer-events: none;
  }

  .glow-bottom {
    position: absolute;
    bottom: -20%;
    left: 20%;
    width: 60%;
    height: 60%;
    background: radial-gradient(ellipse at center,
      rgba(59,130,246,0.08) 0%,
      transparent 65%);
    z-index: 1;
    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.025;
    background-image:
      linear-gradient(rgba(59,130,246,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,1) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
    background: linear-gradient(to top, #0a0a0a 0%, #0a0a0a 30%, transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

  .scan-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg,
      transparent,
      rgba(59,130,246,0.6),
      transparent);
    z-index: 3;
    animation: scan 4s ease-in-out infinite;
    opacity: 0;
  }

  @keyframes scan {
    0%   { top: 0%;   opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.3; }
    100% { top: 100%; opacity: 0; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 6rem;
    max-width: 700px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(59,130,246,0.35);
    background: rgba(59,130,246,0.08);
    color: #93c5fd;
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 999px;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.6s ease 0.1s forwards;
    letter-spacing: 0.02em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3b82f6;
    box-shadow: 0 0 8px #3b82f6;
    animation: pulseDot 2s ease infinite;
    flex-shrink: 0;
  }

  .badge-divider {
    width: 1px;
    height: 12px;
    background: rgba(59,130,246,0.3);
    flex-shrink: 0;
  }

  .microsoft-badge-icon {
    flex-shrink: 0;
    display: block;
  }

  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 8px #3b82f6; }
    50%       { box-shadow: 0 0 18px #3b82f6; }
  }

  .hero-title {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    line-height: 1.1;
    color: #ffffff;
    letter-spacing: -0.03em;
  }

  .hero-title .accent {
    color: #3b82f6;
    text-shadow:
      0 0 30px rgba(59,130,246,0.7),
      0 0 60px rgba(59,130,246,0.35),
      0 0 100px rgba(59,130,246,0.15);
  }

  .hero-title-row {
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.7s ease 0.25s forwards;
  }

  .hero-logo-wrap {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    pointer-events: none;
    width: clamp(400px, 50vw, 750px);
  }

  .hero-logo {
    width: 100%;
    height: auto;
    display: block;
    animation: hologram-glitch 4s ease-in-out infinite;
  }

  @keyframes hologram-glitch {
    /* Estable - la mayor parte del tiempo */
    0%, 28%, 72%, 100% {
      opacity: 1;
      filter: none;
      transform: none;
      clip-path: inset(0);
    }
    /* La señal empieza a vibrar */
    30% {
      opacity: 0.85;
      filter: brightness(1.4) drop-shadow(2px 0 0 rgba(0,255,255,0.5)) drop-shadow(-2px 0 0 rgba(255,0,255,0.5));
      transform: translateX(3px) skewX(0.3deg);
      clip-path: inset(0);
    }
    /* Se rompe en barras horizontales - primer corte */
    32% {
      opacity: 0.25;
      filter: brightness(2.5) saturate(0) contrast(2);
      transform: translateX(-7px);
      clip-path: inset(12% 0 58% 0);
    }
    /* Barra diferente se desplaza */
    34% {
      opacity: 0.7;
      filter: brightness(0.3) hue-rotate(30deg);
      transform: translateX(4px);
      clip-path: inset(48% 0 8% 0);
    }
    /* Canales de color se separan */
    36% {
      opacity: 0.15;
      filter: brightness(3) drop-shadow(6px 0 0 cyan) drop-shadow(-6px 0 0 magenta);
      transform: translateY(10px);
      clip-path: inset(22% 0 32% 0);
    }
    /* Interferencia múltiple */
    38% {
      opacity: 0.8;
      filter: brightness(0.5) contrast(3) hue-rotate(-15deg);
      transform: translateX(-5px) skewX(-0.6deg);
      clip-path: inset(0 0 72% 0);
    }
    /* Ráfaga de ruido */
    40% {
      opacity: 0.08;
      filter: brightness(4) saturate(0) contrast(4);
      transform: translate(6px, -4px);
      clip-path: inset(62% 0 3% 0);
    }
    /* Empieza a recuperarse */
    42% {
      opacity: 0.65;
      filter: brightness(0.4) hue-rotate(20deg);
      transform: translateX(-3px);
      clip-path: inset(8% 0 18% 0);
    }
    /* Casi estable */
    44% {
      opacity: 0.9;
      filter: brightness(1.4) contrast(1.3);
      transform: translateX(2px);
      clip-path: inset(0);
    }
    /* Último parpadeo */
    46% {
      opacity: 0.2;
      filter: brightness(2.5);
      transform: none;
      clip-path: inset(28% 0 42% 0);
    }
    /* Recuperación total */
    48% {
      opacity: 1;
      filter: none;
      transform: none;
      clip-path: inset(0);
    }
    /* Post-efecto sutil */
    50% {
      opacity: 1;
      filter: brightness(1.15);
    }
    52% {
      opacity: 1;
      filter: none;
    }
  }

  @media (max-width: 768px) {
    .hero-logo-wrap {
      right: 50%;
      top: 38%;
      transform: translate(50%, -50%);
      z-index: 1;
      opacity: 0.25;
      width: clamp(800px, 150vw, 1100px);
    }
    .hero-logo {
      animation: hologram-glitch 4s ease-in-out infinite;
    }
    #particles-canvas {
      z-index: 0;
    }
  }

  .hero-subtitle {
    font-size: 16px;
    color: #9ca3af;
    line-height: 1.75;
    max-width: 460px;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.6s ease 0.45s forwards;
  }

  .hero-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(14px);
    animation: fadeUp 0.6s ease 0.6s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #3b82f6;
    color: white;
    font-size: 14px;
    font-weight: 600;
    padding: 13px 28px;
    border-radius: 999px;
    text-decoration: none;
    box-shadow:
      0 0 24px rgba(59,130,246,0.5),
      0 0 48px rgba(59,130,246,0.2);
    transition: box-shadow 0.3s ease, transform 0.2s ease, background 0.2s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background: #2563eb;
    box-shadow:
      0 0 40px rgba(59,130,246,0.7),
      0 0 80px rgba(59,130,246,0.35);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #e5e7eb;
    font-size: 14px;
    font-weight: 500;
    padding: 13px 28px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.18);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: rgba(255,255,255,0.45);
    color: white;
    transform: translateY(-2px);
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const wrapper = canvas.parentElement!;

  type Particle = { x: number; y: number; vx: number; vy: number; r: number; alpha: number };
  let W: number, H: number, particles: Particle[];

  function resize() {
    W = canvas.width = wrapper.offsetWidth;
    H = canvas.height = wrapper.offsetHeight;
  }

  function createParticles() {
    particles = Array.from({ length: 90 }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 1.5 + 0.8,
      alpha: Math.random() * 0.4 + 0.15,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(59,130,246,${p.alpha})`;
      ctx.shadowColor = '#3b82f6';
      ctx.shadowBlur = 8;
      ctx.fill();
      ctx.shadowBlur = 0;

      for (let j = i + 1; j < particles.length; j++) {
        const q = particles[j];
        const dx = p.x - q.x, dy = p.y - q.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 130) {
          const opacity = (1 - dist / 130) * 0.18;
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = `rgba(59,130,246,${opacity})`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }

  resize();
  createParticles();
  draw();
  window.addEventListener('resize', () => { resize(); createParticles(); });
</script>
